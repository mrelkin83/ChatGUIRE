{
  "name": "saas-omnichannel",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test:ci": "turbo test --concurrency=1",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
